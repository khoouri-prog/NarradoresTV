<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- WebView para navegar a FutbolLibre -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

    <!-- Panel de control del delay (oculto hasta presionar MENU) -->
    <LinearLayout
        android:id="@+id/panelDelay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp"
        android:background="#CC000000"
        android:visibility="gone">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙 NarradoresTV"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Control de sincronización de narración"
            android:textSize="16sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="40dp" />

        <!-- Número del delay grande -->
        <TextView
            android:id="@+id/tvDelay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.0 seg"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="#00C853"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="delay de narración"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="48dp" />

        <!-- Instrucciones -->
        <TextView
            android:id="@+id/tvInstrucciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textColor="#CCCCCC"
            android:lineSpacingMultiplier="1.4"
            android:gravity="center" />

    </LinearLayout>

</FrameLayout>
